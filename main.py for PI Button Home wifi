import os
import sys
import queue
import sounddevice as sd
import vosk
import json
import time
import wave
import asyncio
import websockets
from datetime import datetime

# ================= CONFIGURATION =================
SERVER_URI = "ws://192.168.1.34:8765" 
DEVICE_ID = "Node_C"
USER_NAME = "Manoj"

BASE_DIR = os.path.dirname(os.path.abspath(__file__))
MODEL_PATH = os.path.join(BASE_DIR, "model")
STORAGE_FOLDER = os.path.join(BASE_DIR, "outbox")

GRAMMAR = '["charlie", "button", "hey", "computer", "wake", "up", "[unk]"]'

RECORD_DURATION = 4  
WAIT_BEFORE_RECORD = 0.2 
COOLDOWN_AFTER_RECORD = 1.0 

SAMPLE_RATE = 16000
BLOCK_SIZE = 4000
CHANNELS = 1

if not os.path.exists(STORAGE_FOLDER): os.makedirs(STORAGE_FOLDER)

# ================= SETUP =================
if not os.path.exists(MODEL_PATH):
    print(f"❌ Error: Model folder not found at {MODEL_PATH}")
    sys.exit(1)

vosk.SetLogLevel(-1)
model = vosk.Model(MODEL_PATH)
rec = vosk.KaldiRecognizer(model, SAMPLE_RATE, GRAMMAR)

q = queue.Queue()
last_audio_time = time.time()

def audio_callback(indata, frames, ctime, status):
    global last_audio_time
    if status and "overflow" not in str(status): 
        print(f"⚠️ Mic Status: {status}", file=sys.stderr)
        
    last_audio_time = time.time() 
    q.put(bytes(indata))

def save_wave_file(filename, audio_data):
    with wave.open(filename, 'wb') as wf:
        wf.setnchannels(CHANNELS)
        wf.setsampwidth(2)
        wf.setframerate(SAMPLE_RATE)
        wf.writeframes(audio_data)

async def upload_worker():
    """Persistent Uploader."""
    print("📡 Uploader Service Started.")
    
    while True:
        try:
            files = [f for f in os.listdir(STORAGE_FOLDER) if f.endswith(".wav")]
            if not files:
                await asyncio.sleep(1)
                continue

            print(f"📡 Found {len(files)} files. Connecting...")
            
            async with websockets.connect(SERVER_URI, ping_interval=None) as websocket:
                await websocket.send(json.dumps({
                    "type": "handshake", "device_id": DEVICE_ID, "user": USER_NAME
                }))

                while True:
                    files = [f for f in os.listdir(STORAGE_FOLDER) if f.endswith(".wav")]
                    if not files:
                        break 
                    
                    files.sort()
                    filename = files[0]
                    filepath = os.path.join(STORAGE_FOLDER, filename)
                    
                    print(f"📤 Sending: {filename}...")
                    await websocket.send(json.dumps({"type": "start_upload", "filename": filename}))
                    
                    with open(filepath, "rb") as f:
                        await websocket.send(f.read())
                        
                    await websocket.send(json.dumps({"type": "end_upload"}))
                    response = await websocket.recv()
                    print(f"✅ Delivered: {filename}")
                    
                    os.remove(filepath)
                    await asyncio.sleep(0.01) 
                    
        except (ConnectionRefusedError, OSError):
            print("⚠️ Server unreachable. Retrying in 5s...") 
            await asyncio.sleep(5)
        except Exception as e:
            print(f"⚠️ Connection Error: {e}")
            await asyncio.sleep(5)

async def main_loop():
    asyncio.create_task(upload_worker())
    print(f"🚀 UNSTOPPABLE MODE: Listening...")

    while True: 
        global last_audio_time
        last_audio_time = time.time()
        with q.mutex: q.queue.clear()
        
        try:
            with sd.RawInputStream(samplerate=SAMPLE_RATE, blocksize=BLOCK_SIZE, 
                                   device=None, dtype='int16', channels=CHANNELS, 
                                   callback=audio_callback):
                print("🎤 Microphone Active.")
                
                while True:
                    # 1. Hardware Watchdog
                    if time.time() - last_audio_time > 2.0:
                        print("⚠️ Watchdog: Microphone stalled! Rebooting driver...")
                        break 

                    # 2. 🧹 THE BACKLOG SWEEPER (Now with AI Reset!)
                    # Allow up to 2 seconds of buffer (8 chunks). If more, we fell behind.
                    if q.qsize() > 8: 
                        print("🧹 Network upload delayed us. Flushing audio queue to catch up...")
                        with q.mutex: q.queue.clear()
                        rec.Reset() # <--- THE CRITICAL FIX. Wipes the AI's corrupted memory.
                        continue

                    # 3. Normal Processing
                    try:
                        data = q.get_nowait()
                    except queue.Empty:
                        await asyncio.sleep(0.01)
                        continue

                    if rec.AcceptWaveform(data):
                        pass
                    else:
                        res = json.loads(rec.PartialResult())
                        text = res.get("partial", "")

                        if len(text) > 3 and ("charlie" in text or "button" in text):
                            print(f"\n⚡ TRIGGER: '{text}'")
                            
                            await asyncio.sleep(WAIT_BEFORE_RECORD)
                            
                            with q.mutex: q.queue.clear()
                            print(f"🔴 RECORDING...")
                            frames = []
                            bytes_needed = SAMPLE_RATE * RECORD_DURATION * 2
                            bytes_captured = 0
                            
                            while bytes_captured < bytes_needed:
                                if time.time() - last_audio_time > 2.0:
                                    print("⚠️ Mic died during recording!")
                                    break
                                    
                                try:
                                    chunk = q.get_nowait()
                                    frames.append(chunk)
                                    bytes_captured += len(chunk)
                                except queue.Empty:
                                    await asyncio.sleep(0.01)
                            
                            timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
                            filename = f"{STORAGE_FOLDER}/{timestamp}_{USER_NAME}.wav"
                            save_wave_file(filename, b''.join(frames))
                            print(f"💾 Captured.")
                            
                            rec.Reset()
                            with q.mutex: q.queue.clear()
                            last_audio_time = time.time() 
                            await asyncio.sleep(COOLDOWN_AFTER_RECORD)
                            print(f"👂 Listening...")
                            
                    await asyncio.sleep(0.001)

        except Exception as e:
            print(f"❌ Audio Stream Crashed: {e}")
            await asyncio.sleep(2) 

if __name__ == "__main__":
    try:
        asyncio.run(main_loop())
    except KeyboardInterrupt:
        print("\n👋 Stopping...")
